<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MigrationWizard 2.x"
        Height="260"
        Width="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Ligne 0 : Titre du champ dossier -->
        <TextBlock Grid.Row="0"
                   Text="Dossier d'export / import du profil :"
                   FontWeight="Bold"
                   Margin="0,0,0,5"/>

        <!-- Ligne 1 : TextBox + bouton Parcourir -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal">
            <TextBox x:Name="txtFolderPath"
                     Width="360"
                     Margin="0,0,5,0"/>
            <Button x:Name="btnBrowse"
                    Content="Parcourir..."
                    Width="100"/>
        </StackPanel>

        <!-- Ligne 2 : petit label 'Actions' -->
        <TextBlock Grid.Row="2"
                   Text="Actions :"
                   Margin="0,10,0,5"
                   FontStyle="Italic"/>

        <!-- Ligne 3 : Boutons Export / Import -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal">
            <Button x:Name="btnExport"
                    Content="Exporter le profil"
                    Width="150"
                    Margin="0,0,10,0"/>
            <Button x:Name="btnImport"
                    Content="Importer le profil"
                    Width="150"/>
        </StackPanel>

        <!-- Ligne 4 : Zone de statut -->
        <TextBlock x:Name="lblStatus"
                   Grid.Row="4"
                   Margin="0,10,0,0"
                   Text="Prêt."
                   TextWrapping="Wrap"
                   Foreground="Gray"/>
    </Grid>
</Window>
